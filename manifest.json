{
  "manifest_version": 3,
  "name": "Claude Usage Projections",
  "description": "Adds linear budget and projected usage bars to Claude's usage settings page.",
  "version": "1.2",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/settings/usage*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-usage-projections@sawasawasawa"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
